# ══════════════════════════════════════════════════════
#   WhatsApp News Agent v4 — Environment Variables
#   ⚠️  NEVER commit this file to GitHub!
#   Add .env to your .gitignore immediately.
# ══════════════════════════════════════════════════════

# ── NVIDIA NIM ─────────────────────────────────────────
# Get fresh key at: build.nvidia.com → API Keys
NVIDIA_API_KEY=nvapi-your-NEW-key-here

# ── News Sources ───────────────────────────────────────
# TheNewsAPI.com → thenewsapi.com/dashboard
THENEWSAPI_KEY=your-NEW-thenewsapi-key

# NewsAPI.org → newsapi.org/account
NEWSAPI_KEY=your-NEW-newsapi-key

# WorldNewsAPI.com → worldnewsapi.com/dashboard
WORLDNEWSAPI_KEY=your-NEW-worldnewsapi-key

# ── Twilio WhatsApp ────────────────────────────────────
# ⚠️  Generate FRESH credentials at: console.twilio.com
# Account → Settings → API keys & tokens → Rotate Auth Token

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-NEW-auth-token-here

# Your Twilio WhatsApp number
# Sandbox (free testing): whatsapp:+14155238886
# Production: whatsapp:+1XXXXXXXXXX  (your approved number)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Server ─────────────────────────────────────────────
PORT=3001

# -- MongoDB Atlas --
MONGODB_URI=
